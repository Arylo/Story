{
  "servers": {
    "obsidian": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-obsidian"
      ],
      "envFile": "${workspaceFolder}/.env"
    },
    "web-search": {
      "command": "npx",
      "args": [
        "open-websearch@latest"
      ],
      "env": {
        "MODE": "both",
        "DEFAULT_SEARCH_ENGINE": "bing",
        "ALLOWED_SEARCH_ENGINES": "bing,baidu"
      }
    },
    "local-rag": {
      "command": "npx",
      "args": ["-y", "mcp-local-rag"]
    }
  }
}